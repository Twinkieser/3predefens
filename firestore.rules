rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 0. Global Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    // --- Helpers ---
    function isSignedIn() { return request.auth != null; }
    function isVerified() { return isSignedIn() && request.auth.token.email_verified == true; }
    function isOwner(uid) { return isSignedIn() && request.auth.uid == uid; }
    function isValidId(id) { return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$'); }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // --- Validation Helpers ---
    
    function isValidUser(data) {
      return data.uid is string &&
             data.email is string &&
             data.displayName is string &&
             (data.photoURL == null || data.photoURL is string) &&
             data.points is number &&
             data.streak is number &&
             data.level is string &&
             data.badges is list &&
             (data.createdAt == null || data.createdAt is timestamp) &&
             (data.lastActive == null || data.lastActive is timestamp || data.lastActive is number);
    }

    function isValidScan(data) {
      return data.uid is string &&
             data.id is string &&
             (data.imageUrl == null || data.imageUrl is string) &&
             data.category is string &&
             data.confidence is number &&
             data.pointsEarned is number &&
             data.tips is string &&
             data.instructions is string;
    }

    // --- Collection Rules ---

    match /users/{userId} {
      // Identity Pillar: Owner can get their own doc (or any user if we allow it)
      allow get: if isSignedIn();
      
      // Leaderboard Pillar: Signed in users can list profiles (needed for rank/stats)
      allow list: if isSignedIn();
      
      allow create: if isOwner(userId) && isVerified() && 
                      isValidUser(incoming()) &&
                      incoming().uid == request.auth.uid;
      
      allow update: if isOwner(userId) && isVerified() && 
                      isValidUser(incoming()) &&
                      incoming().uid == existing().uid;

      match /scans/{scanId} {
        // Access Pillar
        allow get: if isOwner(userId);
        
        // Query Pillar
        allow list: if isOwner(userId);
        
        allow create: if isOwner(userId) && isVerified() &&
                        isValidScan(incoming()) &&
                        incoming().uid == request.auth.uid;
        
        allow delete: if isOwner(userId) && isVerified();
      }
    }

    match /globalStats/{docId} {
      allow read: if isSignedIn();
      allow write: if false;
    }
  }
}
